<div class="layout">
  <div class="grid grid--cols-5">
    <div class="col col--start gap text--center">
      <span class="title font--bold">{{ label0 }}</span>
      <div class="w--full">
        <img class="weather-icon" src="https://usetrmnl.com/images/plugins/weather/{{ image_day[o0] }}">
        <br/>
        <span class="description text-stroke">{{ condition[o0] }}</span>
      </div>
      <div class="w--full">
        <span class="value value--xsmall">{{ daily_temps_max[o0] | round }}° / {{ daily_temps_min[o0] | round }}°</span>
      </div>
      <div class="w--full">
        <div class="flex flex--row gap--xsmall">
          <img class="weather-icon-mini" src="https://usetrmnl.com/images/plugins/weather/wi-rain.svg">
          <span class="value value--xxsmall mr--1">{{ daily_rain_prob[o0] | round }}%</span>
          <img class="weather-icon-mini" src="https://usetrmnl.com/images/plugins/weather/{{ daily_wind_icon[o0] }}" />
          <span class="value value--xxsmall">{{ daily_wind_speed[o0] | round }}<sup>m</sup>/<sub>s</sub></span>
        </div>
      </div>
    </div>
