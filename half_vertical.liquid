<div class="layout layout--col gap--space-between">
  <div class="grid">
    <div class="row row--center col--span-2 col--end">
      <img class="weather-image" src="https://usetrmnl.com/images/plugins/weather/{{ image_day[0] }}">
    </div>
    <div class="col col--span-3 col--end gap--medium">
      <div class="item">
        <div class="meta"></div>
        <div class="icon">
          <img class="weather-icon" src="https://usetrmnl.com/images/plugins/weather/wi-thermometer.svg">
        </div>
        <div class="content">
          <span class="value value--small">{{ daily_temps_max[0] | round }}°</span>
          <span class="label">High</span>
        </div>
      </div>
      <div class="item">
        <div class="meta"></div>
        <div class="icon">
          <img class="weather-icon" src="https://usetrmnl.com/images/plugins/weather/wi-thermometer-exterior.svg">
        </div>
        <div class="content">
          <span class="value value--small">{{ daily_temps_min[0] | round }}°</span>
          <span class="label">Low</span>
        </div>
      </div>
      <div class="item">
        <div class="meta"></div>
        <div class="icon">
          <img class="weather-icon" src="https://usetrmnl.com/images/plugins/weather/wi-rain.svg">
        </div>
        <div class="content">
          <span class="value value--small">{{ daily_rain_prob[0] | round }}%</span>
          <span class="label">Rain</span>
        </div>
      </div>
    </div>
  </div>
  <div class="border--h-6 w--full"></div>
  <!-- forecast -->
  <div class="grid grid--cols-3">
    {% for i in (1..3) %}
    <div class="col col--start gap--medium text--center">
      {% if forloop.index == 1 %}
      <span class="title font--bold">Tomorrow</span>
      {% else %}
      <span class="title font--bold">{{ daily_dates[i] | date: "%A" }}</span>
      {% endif %}
      <div class="w--full">
        <img class="weather-icon" src="https://usetrmnl.com/images/plugins/weather/{{ image_day[i] }}">
        <br/>
        <span class="description">{{ condition[i] }}</span>
      </div>
      <div class="w--full">
        <span class="value value--xsmall">{{ daily_temps_max[i] | round }}° / {{ daily_temps_min[i] | round }}°</span>
      </div>
      <div class="w--full">
        <div class="flex flex--row gap--xsmall">
          <img class="weather-icon-mini image-stroke" src="https://usetrmnl.com/images/plugins/weather/wi-rain.svg" />
          <span class="value value--xxsmall text-stroke">{{ daily_rain_prob[i] | round }}%</span>
          <img class="weather-icon-mini image-stroke" src="https://usetrmnl.com/images/plugins/weather/{{ daily_wind_icon[i] }}">
          <span class="value value--xxsmall text-stroke mr--1">{{ daily_wind_label[i] }}<sup>m</sup>/<sub>s</sub></span>
        </div>
      </div>
    </div>
    {% endfor %}
  </div>
</div>
<div class="title_bar">
  <img class="image" src="https://procore-marketplace.s3.amazonaws.com/production/uploads/603f8d6d-ddbd-4e63-b6e4-c1d4e8272bbc.png">
  <h1 class="title">Tomorrow.io Forecast</h1>
  <span class="instance">{{ trmnl.plugin_settings.custom_fields_values.location_name }}</span>
</div>
